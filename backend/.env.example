# ============================================================
# TRIVIO — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA suba o .env para o Git. Ele já está no .gitignore.
# ============================================================

# Servidor
PORT=3001
NODE_ENV=development

# URL base do servidor (usada para montar links de callback)
# Em produção, substitua pelo seu domínio real
BASE_URL=http://localhost:3001

# JWT
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria
JWT_EXPIRES_IN=24h

# ────────────────────────────────────────────────────────────
# PAGAR.ME — Integração de Pagamentos
# ────────────────────────────────────────────────────────────
# Obtenha suas chaves em: https://dashboard.pagar.me
# Para testes, use as chaves de SANDBOX (prefixo sk_test / pk_test)
# Para produção, use as chaves LIVE (prefixo sk_live / pk_live)
# ────────────────────────────────────────────────────────────

# Chave secreta — usada no backend para autenticar na API
# NUNCA exponha esta chave no frontend
PAGARME_SECRET_KEY=sk_test_COLE_SUA_CHAVE_AQUI

# Chave pública — pode ser usada no frontend (Pagar.me.js)
PAGARME_PUBLIC_KEY=pk_test_COLE_SUA_CHAVE_AQUI

# Segredo do Webhook — gerado por você, configurado no dashboard do Pagar.me
# Use uma string longa e aleatória. Exemplo no terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAGARME_WEBHOOK_SECRET=gere_uma_string_aleatoria_aqui

# ────────────────────────────────────────────────────────────
# CLOUDINARY — Upload de imagens (já existia no projeto)
# ────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# Email (opcional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=seu_email@example.com
SMTP_PASSWORD=sua_senha_email
